proc helper
    nop
end

proc nested_if
    push.0
    eq.0
    if.true
        exec.helper
    else
        nop
    end
end

proc nested_repeat
    repeat.5
        exec.helper
    end
end

proc nested_while
    push.0
    eq.0
    while.true
        exec.helper
        push.1
        eq.0
    end
end

proc deeply_nested
    push.0
    eq.0
    if.true
        push.0
        eq.0
        while.true
            push.0
            eq.0
            if.true
                exec.helper
            else
                nop
            end
            push.1
            eq.0
        end
    else
        nop
    end
end
