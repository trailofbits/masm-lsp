proc helper
    nop
end

proc invalid_if
    if.true
        exec.helper
    else
        push.0
    end
end

proc invalid_while
    while.true
        exec.helper
    end
end

proc invalid_deeply_nested
    if.true
        repeat.3
            while.true
                exec.helper
            end
        end
    else
        push.0
    end
end
